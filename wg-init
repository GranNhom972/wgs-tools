#!/usr/bin/env python3
import os
import subprocess

WG_DIR = "/etc/wireguard"
CONF_FILE = os.path.join(WG_DIR, "wg0.conf")
KEY_PRIVATE = os.path.join(WG_DIR, "privatekey")
KEY_PUBLIC = os.path.join(WG_DIR, "publickey")


def check_root():
    if os.geteuid() != 0:
        print("Ce script doit être exécuté en root")
        exit(1)


def detect_default_interface():
    try:
        result = subprocess.run(
            ["ip", "route"],
            capture_output=True,
            text=True,
            check=True
        )
        for line in result.stdout.splitlines():
            if line.startswith("default"):
                return line.split()[4]  # 5ème champ = interface
    except subprocess.CalledProcessError:
        print("Impossible de détecter l'interface réseau")
        exit(1)
    return "eth0"


def generate_keys():
    if not os.path.exists(KEY_PRIVATE):
        priv = subprocess.run(["wg", "genkey"], capture_output=True, text=True, check=True).stdout.strip()
        pub = subprocess.run(["wg", "pubkey"], input=priv, capture_output=True, text=True, check=True).stdout.strip()
        with open(KEY_PRIVATE, "w") as f:
            f.write(priv)
        with open(KEY_PUBLIC, "w") as f:
            f.write(pub)
        os.chmod(KEY_PRIVATE, 0o600)
        os.chmod(KEY_PUBLIC, 0o600)
        print("Clés WireGuard générées")
    else:
        print("Clés WireGuard déjà existantes")

    with open(KEY_PRIVATE, "r") as f:
        private_key = f.read().strip()
    return private_key


def create_conf(private_key, interface):
    conf_content = f"""[Interface]
Address = 10.0.0.1/24
SaveConfig = true
PostUp = iptables -A FORWARD -i wg0 -j ACCEPT; iptables -t nat -A POSTROUTING -o {interface} -j MASQUERADE
PostDown = iptables -D FORWARD -i wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o {interface} -j MASQUERADE
ListenPort = 51820
PrivateKey = {private_key}
"""
    with open(CONF_FILE, "w") as f:
        f.write(conf_content)
    os.chmod(CONF_FILE, 0o600)
    print(f"Fichier {CONF_FILE} créé avec succès")


def main():
    check_root()
    os.makedirs(WG_DIR, exist_ok=True)
    os.chmod(WG_DIR, 0o700)
    interface = detect_default_interface()
    print(f"Interface principale détectée : {interface}")
    private_key = generate_keys()
    create_conf(private_key, interface)
    print("Vous pouvez maintenant démarrer WireGuard : sudo wg-quick up wg0")


if __name__ == "__main__":
    main()

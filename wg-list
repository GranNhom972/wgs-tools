#!/usr/bin/env python3
import os
import sys
import subprocess
import time
import math

# --- CONFIGURATION ---
WG_INTERFACE = "wg0"
WG_CONFIG = f"/etc/wireguard/{WG_INTERFACE}.conf"

# --- VERIFICATIONS ---
if os.geteuid() != 0:
    print("❌ Erreur : Ce script doit être lancé avec sudo !")
    sys.exit(1)

if not os.path.exists(WG_CONFIG):
    print(f"❌ Erreur : Le fichier {WG_CONFIG} n'existe pas.")
    sys.exit(1)

# --- FONCTIONS UTILITAIRES ---
def convert_size(size_bytes):
    if size_bytes == 0: return "0 B"
    size_name = ("B", "KB", "MB", "GB", "TB")
    i = int(math.floor(math.log(size_bytes, 1024)))
    p = math.pow(1024, i)
    s = round(size_bytes / p, 2)
    return f"{s} {size_name[i]}"

def get_time_ago(timestamp):
    if timestamp == 0: return "Jamais"
    diff = int(time.time() - timestamp)
    if diff < 60: return f"{diff} sec"
    elif diff < 3600: return f"{diff // 60} min"
    elif diff < 86400: return f"{diff // 3600} h"
    else: return f"{diff // 86400} jours"

# --- 1. LECTURE DE LA CONFIG (LOGIQUE STRICTE) ---
peers_map = {}
current_client_name = None

try:
    with open(WG_CONFIG, "r") as f:
        for line in f:
            stripped = line.strip()

            # Détection stricte, identique à wg-remove
            if stripped.startswith("### Client:"):
                # On récupère tout ce qui est après "### Client:"
                current_client_name = stripped.split("### Client:", 1)[1].strip()
                continue

            # On ne capture la clé que si un client a été identifié juste avant
            if stripped.startswith("PublicKey") and current_client_name:
                # Nettoyage de la clé (suppression commentaires inline éventuels)
                pub_key = stripped.split("=", 1)[1].split("#")[0].strip()
                peers_map[pub_key] = {'name': current_client_name}
                # Note: On ne reset pas current_client_name ici, au cas où
                # la config aurait plusieurs blocs pour le même client (rare mais possible)
                # Il sera remplacé au prochain "### Client:"

except Exception as e:
    print(f"❌ Erreur lecture config : {e}")
    sys.exit(1)

# --- 2. LECTURE DU STATUT REEL (wg show) ---
try:
    output = subprocess.check_output(["wg", "show", WG_INTERFACE, "dump"]).decode()
except subprocess.CalledProcessError:
    print(f"❌ Impossible d'interroger l'interface {WG_INTERFACE}.")
    sys.exit(1)

peers_status = []
for line in output.strip().split('\n'):
    parts = line.split('\t')
    if len(parts) >= 8:
        pub_key = parts[0]
        
        # Recherche du nom
        name = "Inconnu (Manuel)"
        if pub_key in peers_map:
            name = peers_map[pub_key]['name']
            
        peers_status.append({
            'name': name,
            'ip': parts[3],
            'handshake': int(parts[4]),
            'rx': int(parts[5]),
            'tx': int(parts[6])
        })

# --- 3. AFFICHAGE DU TABLEAU ---
peers_status.sort(key=lambda x: x['name'])

print(f"\n📊 État des clients WireGuard ({len(peers_status)} connectés au serveur)\n")
header = f"{'NOM':<20} | {'IP INTERNE':<18} | {'DERNIÈRE ACTIVITÉ':<18} | {'DATA REÇU':<12} | {'DATA ENVOYÉ':<12}"
print(header)
print("-" * len(header))

for peer in peers_status:
    ts = peer['handshake']
    time_str = get_time_ago(ts)
    
    status_icon = "🔴"
    if ts > 0 and (time.time() - ts) < 180: status_icon = "🟢"
    elif ts > 0: status_icon = "🟡"

    display_name = f"{status_icon} {peer['name']}"
    if len(display_name) > 20: display_name = display_name[:19] + "…"
    
    print(f"{display_name:<20} | {peer['ip']:<18} | {time_str:<18} | {convert_size(peer['rx']):<12} | {convert_size(peer['tx']):<12}")

print("\nLegende : 🟢 Actif (<3min) | 🟡 Inactif | 🔴 Jamais connecté\n")
